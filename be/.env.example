# Archivo: .env.example
# Descripción: Variables de entorno necesarias para ejecutar el backend.
# ¿Para qué? Documentar la configuración requerida sin exponer valores reales.
# ¿Impacto? El desarrollador copia este archivo como .env y completa los valores.
#            SIN este archivo, no queda claro qué variables son necesarias.

# --- Base de datos ---
DATABASE_URL=postgresql://nn_user:nn_password@localhost:5432/nn_auth_db

# --- JWT ---
# Mínimo 32 caracteres, completamente aleatorio
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Servidor ---
PORT=8000
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# --- SMTP (Mailpit en desarrollo) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@nn-company.com
