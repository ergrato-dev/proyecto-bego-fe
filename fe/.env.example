# Archivo: .env.example
# Descripción: Variables de entorno del frontend — copiar a .env y ajustar.
# ¿Para qué? Documentar las variables necesarias sin exponer valores reales.
# ¿Impacto? Sin VITE_API_URL correcto, todas las llamadas a la API fallarán.
#
# IMPORTANTE: Solo las variables con prefijo VITE_ son accesibles desde el
# código del browser (las demás son ignoradas por Vite por seguridad).

# URL base de la API del backend
VITE_API_URL=http://localhost:8000/api/v1
